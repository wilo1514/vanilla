PORT=3009
DB_DRIVER=memory

# Hostinger MySQL production values
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

MAIL_LIST_DIR=../mail_list
EXPORT_DIR=./exports
PUBLIC_BASE_URL=http://localhost:3009
PUBLIC_SITE_DIR=../website/current_site/dist
CORS_ORIGIN=https://moccasin-mouse-280097.hostingersite.com
PHYSICAL_MAILING_ADDRESS="[Physical Mailing Address]"

# Admin and Cron security
ADMIN_TOKEN=replace-with-long-random-admin-token
JOB_SECRET=replace-with-long-random-job-secret

# Hostinger Email SMTP/IMAP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_REPLY_TO=
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASSWORD=

# Optional OpenAI draft assistance. Leave empty to use deterministic templates only.
ENABLE_OPENAI_DRAFT_ASSIST=false
OPENAI_DRAFT_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

TEST_EMAIL_RECIPIENT=your-test-recipient@example.com
TEST_REPLY_TO=your-reply-to@example.com
EMAIL_DRY_RUN=true
